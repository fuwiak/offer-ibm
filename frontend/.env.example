VITE_API_BASE='http://localhost:3001/api' # Use this URL when developing locally
# VITE_OFFER_KP_PERF_LOG=true  # Log fetch timing + page load metrics in browser console
# VITE_SLOW_REQUEST_MS=500       # Mark frontend fetches slower than this as SLOW
# In production: localStorage.setItem('offerKp_perf_log','1') to enable without rebuild
# VITE_OFFER_KP_PUBLIC_WORKSPACE='offerKp-public'
# VITE_OFFER_KP_PARTNER_WORKSPACE='offerKp-partner'
# VITE_OFFER_KP_SKIP_ONBOARDING=true  # default: skip legacy wizard; set false to restore it
# VITE_API_BASE="https://$CODESPACE_NAME-3001.$GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN/api" # for GitHub Codespaces
# VITE_API_BASE='/api' # Use this URL deploying on non-localhost address OR in docker.
