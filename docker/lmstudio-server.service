[Unit]
Description=LM Studio local server
After=network.target

[Service]
Type=oneshot
RemainAfterExit=yes
User=root
Environment=PATH=/root/.lmstudio/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin
ExecStart=/root/.lmstudio/bin/lms server start --port 1234
ExecStartPost=/opt/offer-kp/app/docker/lmstudio-load-brain.sh
ExecStop=/root/.lmstudio/bin/lms server stop
Restart=no

[Install]
WantedBy=multi-user.target
