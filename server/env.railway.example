# Локальная копия Railway Variables (опционально).
# Скопируйте: cp env.railway.example .env.railway и заполните из Railway dashboard.
# Файл .env.railway в gitignore — секреты не коммитить.
#
# Приоритет: server/.env и ../.env → затем fallback из этого файла / Railway process.env

DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=
DATABASE_URL=

SHOP_DB_ENRICH=1
SHOP_DB_SEARCH_AGENT=1
SHOP_DB_SEARCH_AGENT_LLM=1
SHOP_BASE_URL=https://purolat.com
ELI_DISABLED=1

LLM_PROVIDER=lmstudio
LMSTUDIO_BASE_PATH=http://87.228.90.43:1234/v1
LMSTUDIO_MODEL_PREF=openai/gpt-oss-20b
OLLAMA_BASE_PATH=http://212.41.6.162:11434
OLLAMA_MODEL_PREF=gpt-oss:20b
OLLAMA_CLOUD_FALLBACK=0
OLLAMA_CLOUD_BASE_PATH=https://ollama.com
OLLAMA_CLOUD_MODEL_PREF=gpt-oss:120b
OLLAMA_AUTH_TOKEN=
SHOP_DB_SEARCH_AGENT_LLM=0
# OPENROUTER — опционально, если переключите LLM_PROVIDER=openrouter
OPENROUTER_MODEL_PREF=qwen/qwen3.5-plus-20260420
OPENROUTER_API_KEY=
OPEN_ROUTER_TOKEN=
